# ===========================================
# Zinter AI - Environment Variables
# ===========================================
# Copy this file as .env and fill in your values

# Database URL
# For local dev: file:./db/custom.db
# For Vercel/Turso: libsql://your-db-name-your-org.turso.io
DATABASE_URL=file:./db/custom.db

# Turso Auth Token (only needed for cloud database)
# Get this from: https://turso.tech dashboard → Database → Tokens
DATABASE_AUTH_TOKEN=

# JWT Secret for session tokens (change this to a random string!)
JWT_SECRET=change-this-to-a-random-secret-string

# Google OAuth 2.0 (optional - get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL - set to your Vercel domain after deployment
NEXT_PUBLIC_BASE_URL=http://localhost:3000
