# Database - Local SQLite (for development)
DATABASE_URL=file:/home/z/my-project/db/custom.db
# DIRECT_DATABASE_URL is only needed for Turso (cloud SQLite) deployment
# Leave empty for local development
DIRECT_DATABASE_URL=

# Google OAuth 2.0 (optional - for production, get from Google Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL - change to your Vercel domain after deployment
NEXT_PUBLIC_BASE_URL=http://localhost:3000
